{
  "name": "two-windows-1back",
  "version": "1.0.0",
  "private": true,
  "description": "Two-window selection & sorting app over 1,000,000 elements",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "playwright": "^1.61.1",
    "vite": "^5.4.0"
  }
}
